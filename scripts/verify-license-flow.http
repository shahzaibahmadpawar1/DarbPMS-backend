@baseUrl = http://localhost:5000/api
@token = REPLACE_WITH_BEARER_TOKEN

### 1) Commercial - latest saved
GET {{baseUrl}}/commercial-licenses/latest-saved
Authorization: Bearer {{token}}

### 2) Commercial - save draft
POST {{baseUrl}}/commercial-licenses
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "licenseNo": "COM-QA-001",
  "stationCode": "N101",
  "ownerName": "QA Owner",
  "submit": false
}

### 3) Commercial - submit draft (replace :id)
PUT {{baseUrl}}/commercial-licenses/:id
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "submit": true
}

### 4) Environmental - latest saved
GET {{baseUrl}}/government-licenses/environmental/latest-saved
Authorization: Bearer {{token}}

### 5) Environmental - save draft
POST {{baseUrl}}/government-licenses/environmental
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "issuanceNo": "ENV-QA-001",
  "stationCode": "N101",
  "facilityName": "QA Facility",
  "submit": false
}

### 6) Environmental - submit draft (replace :id)
PUT {{baseUrl}}/government-licenses/environmental/:id
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "submit": true
}

