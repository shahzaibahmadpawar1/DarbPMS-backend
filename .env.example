# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (Supabase Connection Pooler)
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/postgres

# Legacy individual parameters (kept for reference)
DB_HOST=<supabase-host>
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=<your-db-password>

# CORS Configuration
CORS_ORIGIN=https://stg.pms.darbstations.com.sa

# Security
JWT_SECRET=<your-jwt-secret>

# DeepL Translation
# API key for the DeepL translation service (free tier keys end with :fx)
DEEPL_API_KEY=<your-deepl-api-key>
# Run `npx ts-node src/scripts/init-glossary.ts` once to obtain the glossary ID.
DEEPL_GLOSSARY_ID=<your-glossary-id> 
