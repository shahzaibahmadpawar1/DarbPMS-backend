# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (Supabase Connection Pooler)
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/postgres

# Legacy individual parameters (kept for reference)
DB_HOST=<supabase-host>
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=<your-db-password>

# CORS Configuration
CORS_ORIGIN=https://stg.pms.darbstations.com.sa

# Security
JWT_SECRET=<your-jwt-secret>

# DeepL Translation
# API key for the DeepL translation service (free tier keys end with :fx)
DEEPL_API_KEY=<your-deepl-api-key>
# Run `npx ts-node src/scripts/init-glossary.ts` once to obtain the glossary ID.
DEEPL_GLOSSARY_ID=<your-glossary-id> 

# Supabase Storage (backend-managed uploads)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_BUCKET_NAME=pms
MAX_FILE_SIZE_MB=25
ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/png,image/jpeg,application/acad,application/x-acad,application/autocad_dwg,image/vnd.dwg,application/dwg,application/x-dwg
ALLOWED_FILE_EXTENSIONS=.pdf,.doc,.docx,.jpg,.jpeg,.png,.dwg
